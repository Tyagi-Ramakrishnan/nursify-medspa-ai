# App
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/autoledger

# Redis (Railway provides this automatically)
REDIS_URL=redis://localhost:6379

# QuickBooks OAuth 2.0
# Get these from developer.intuit.com
QB_CLIENT_ID=your_quickbooks_client_id
QB_CLIENT_SECRET=your_quickbooks_client_secret
QB_REDIRECT_URI=http://localhost:8000/api/v1/quickbooks/callback
QB_ENVIRONMENT=sandbox  # change to "production" when ready

# Email (daily report delivery)
# Use SendGrid, Mailgun, or any SMTP provider
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
REPORT_FROM_EMAIL=reports@yourmspabrand.com
REPORT_TO_EMAIL=owner@yourmspabrand.com

# Admin login (MVP: single user)
ADMIN_EMAIL=owner@yourmspabrand.com
ADMIN_PASSWORD=change-me-before-deploying
